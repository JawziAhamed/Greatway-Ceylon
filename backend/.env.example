PORT=5000
MONGO_URI=mongodb://localhost:27017/greatway-exports
JWT_SECRET=replace_with_a_secure_random_secret
NODE_ENV=development

# Meta WhatsApp Business Cloud API
# Keep these values server-side only. Never add them to frontend/.env.
WHATSAPP_ACCESS_TOKEN=replace_with_meta_cloud_api_access_token
WHATSAPP_PHONE_NUMBER_ID=replace_with_meta_phone_number_id
WHATSAPP_GRAPH_VERSION=v23.0
WHATSAPP_ADMIN_NUMBER=94725737391

# Optional: disable WhatsApp sending during local work.
BYPASS_WHATSAPP_NOTIFICATION=false

# Optional: use an approved template for production business-initiated messages.
# The template body should have 6 text variables:
# {{1}} customer name, {{2}} email, {{3}} phone, {{4}} product,
# {{5}} message, {{6}} submitted time.
# WHATSAPP_TEMPLATE_NAME=new_inquiry_notification
# WHATSAPP_TEMPLATE_LANGUAGE=en_US
